generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum BrandFont {
  INTER
  MANROPE
  DM_SANS
  SPACE_GROTESK
  LORA
  PLAYFAIR_DISPLAY
  CORMORANT_GARAMOND
  FRAUNCES
}

enum BrandAssetKind {
  LOGO
  LOGO_ALT
  FAVICON
}

enum CustomerAuthProvider {
  GOOGLE
  APPLE
}

enum AppointmentBookingType {
  GUEST
  GOOGLE
  APPLE
}

model Business {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  timezone          String             @default("America/New_York")
  phone             String?
  email             String?
  description       String?
  heroHeadline      String?
  heroSubheadline   String?
  defaultLocale     String             @default("es")
  primaryFont       BrandFont          @default(INTER)
  secondaryFont     BrandFont          @default(PLAYFAIR_DISPLAY)
  primaryColor      String             @default("#1b625a")
  secondaryColor    String             @default("#f2c7bb")
  backgroundColor   String             @default("#f4ece3")
  textColor         String             @default("#221d18")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  adminUsers        AdminUser[]
  appointments      Appointment[]
  brandAssets       BrandAsset[]
  blackoutDates     BlackoutDate[]
  businessHours     BusinessHours[]
  businessHoursDays BusinessHoursDay[]
  services          Service[]
  staffMembers      StaffMember[]
}

model BusinessHoursDay {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  isClosed   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, dayOfWeek])
}

model Service {
  id              String        @id @default(cuid())
  businessId      String
  name            String
  slug            String
  description     String?
  durationMinutes Int
  bufferMinutes   Int           @default(0)
  priceCents      Int
  isActive        Boolean       @default(true)
  sortOrder       Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  appointments    Appointment[]
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, slug])
}

model StaffMember {
  id             String              @id @default(cuid())
  businessId     String
  name           String
  slug           String
  title          String?
  bio            String?
  isActive       Boolean             @default(true)
  sortOrder      Int                 @default(0)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  appointments   Appointment[]
  availabilities StaffAvailability[]
  blackoutDates  BlackoutDate[]
  business       Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, slug])
}

model BusinessHours {
  id         String   @id @default(cuid())
  businessId String
  dayOfWeek  Int
  openTime   String
  closeTime  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId, dayOfWeek, openTime])
}

model StaffAvailability {
  id            String      @id @default(cuid())
  staffMemberId String
  dayOfWeek     Int
  startTime     String
  endTime       String
  isOff         Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([staffMemberId, dayOfWeek])
}

model BlackoutDate {
  id            String       @id @default(cuid())
  businessId    String
  staffMemberId String?
  startsAt      DateTime
  endsAt        DateTime
  reason        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  business      Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  staffMember   StaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([businessId, startsAt, endsAt])
  @@index([staffMemberId, startsAt, endsAt])
}

model Customer {
  id                String               @id @default(cuid())
  name              String?
  email             String?
  image             String?
  authProvider      CustomerAuthProvider
  providerAccountId String
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  appointments      Appointment[]

  @@unique([authProvider, providerAccountId])
  @@index([email])
}

model Appointment {
  id                  String                 @id @default(cuid())
  businessId          String
  serviceId           String
  staffMemberId       String?
  customerId          String?
  customerName        String
  customerEmail       String
  customerPhone       String?
  guestFullName       String?
  guestEmail          String?
  guestPhone          String?
  contactEmail        String?
  contactPhone        String?
  bookingType         AppointmentBookingType @default(GUEST)
  managementTokenHash String?                @unique
  notes               String?
  status              AppointmentStatus      @default(PENDING)
  confirmationCode    String                 @unique
  startAt             DateTime
  endAt               DateTime
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  business            Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer            Customer?              @relation(fields: [customerId], references: [id], onDelete: SetNull)
  service             Service                @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staffMember         StaffMember?           @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)

  @@index([businessId, startAt])
  @@index([customerId])
  @@index([staffMemberId, startAt])
}

model BrandAsset {
  id               String         @id @default(cuid())
  businessId       String
  kind             BrandAssetKind
  originalFilename String
  mimeType         String
  sizeBytes        Int
  data             Bytes
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  business         Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, kind])
}

model AdminUser {
  id           String   @id @default(cuid())
  businessId   String
  name         String
  email        String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  business     Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, email])
}
