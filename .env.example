DATABASE_URL="file:./dev.db"

# Required when enabling optional public customer sign-in.
# Use http://localhost:3000 for local Google testing.
# Use one HTTPS platform domain in production, for example https://yourplatform.com.
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# Google OAuth
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Apple Sign-In OAuth
# Configure Apple against the production platform callback:
# https://yourplatform.com/api/auth/callback/apple
APPLE_CLIENT_ID="replace-with-apple-service-id"
APPLE_CLIENT_SECRET="replace-with-apple-client-secret-jwt"
